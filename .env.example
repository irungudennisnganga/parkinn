# Server
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/parking_altura

# HikCentral
HIK_BASE_URL=http://localhost:3000
HIK_ACCESS_KEY=your_access_key
HIK_SECRET_KEY=your_secret_key
